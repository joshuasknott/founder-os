# FounderOS platform environment
#
# Only put FounderOS-owned infrastructure secrets here.
# User-owned connector credentials are collected in onboarding or Settings and
# stored encrypted per workspace.

# Convex
CONVEX_DEPLOYMENT=
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3000

# Worker authorization
FOUNDEROS_WORKER_TOKEN=

# Connector credential encryption
CONNECTOR_SECRET_ENCRYPTION_KEY=

# FounderOS-owned Google OAuth app
# Used for login and, unless overridden below, Google Workspace connectors.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional FounderOS-owned connector OAuth apps
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Optional FounderOS-owned GitHub App
GITHUB_APP_NAME=founderos-connect
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
