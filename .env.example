# FounderOS platform environment
#
# Only put FounderOS-owned infrastructure secrets here.
# User-owned connector credentials are collected in onboarding or Settings and
# stored encrypted per workspace.

# Convex
CONVEX_DEPLOYMENT=
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Worker authorization
FOUNDEROS_WORKER_TOKEN=

# Local runner
# Preferred local path for hidden Home chat and Work execution. It leases chat
# intake jobs and work from Convex, then writes plain progress/results back.
# LOCAL_RUNNER_ID=founder-laptop
# LOCAL_RUNNER_NAME=FounderOS local runner
# LOCAL_RUNNER_CAPABILITIES=business_reasoning,coding,debugging,planning,product_marketing_docs,document,design,communication,schedule,data,generic
# LOCAL_RUNNER_OUTPUT_CONTRACTS=plain_text,structured_json,library_item,code_changes,public_draft
# LOCAL_RUNNER_MAX_SENSITIVITY=restricted
# LOCAL_RUNNER_APPROVAL_CAPABILITIES=send_email,create_calendar_event,publish_preview,post_externally,spend_money,delete_data,change_live_asset,generic
# LOCAL_RUNNER_POLL_INTERVAL_MS=5000
# LOCAL_RUNNER_HEARTBEAT_TTL_MS=45000
# LOCAL_RUNNER_HEARTBEAT_INTERVAL_MS=15000
# LOCAL_RUNNER_LEASE_MS=600000
# LOCAL_RUNNER_REQUIRE_OPENCODE=true
# LOCAL_RUNNER_SKIP_OPENCODE_CHECK=false

# Hidden model orchestration
# Founder-facing UI must not expose these route names.
# Paid GLM routes below are opencode subscription routes, not separate API keys.
# FOUNDEROS_OPENCODE_CLASSIFICATION_MODEL=zai-coding-plan/glm-4.5-air
# FOUNDEROS_OPENCODE_BUSINESS_MODEL=zai-coding-plan/glm-4.7
# FOUNDEROS_OPENCODE_PLANNING_MODEL=zai-coding-plan/glm-5-turbo
# FOUNDEROS_OPENCODE_CODING_MODEL=zai-coding-plan/glm-5.1
# Optional Home chat override. Do not point routine chat at DeepSeek or free routes.
# FOUNDEROS_OPENCODE_CHAT_MODEL=
# FOUNDEROS_OPENCODE_CHAT_TIMEOUT_MS=120000
# GEMINI_API_KEY=
# GEMINI_VISION_MODEL=gemini-3-flash
# DeepSeek is escalation/review only, not a routine chat/work fallback.
# DEEPSEEK_API_KEY=
# DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro
# FOUNDEROS_ALLOW_EXTERNAL_EMBEDDINGS=false

# Connector credential encryption
CONNECTOR_SECRET_ENCRYPTION_KEY=
# CONNECTOR_OAUTH_STATE_SECRET=

# Optional FounderOS-owned connector OAuth apps
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=

# Optional FounderOS-owned GitHub App.
# Repository import needs metadata and contents read access; issue creation needs issues write access.
GITHUB_APP_NAME=founderos-connect
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Builder worker
# See workers/builder/README.md for full documentation.
BUILDER_PROVIDER=opencode
# BUILDER_AGENT=
# BUILDER_AGENT_TIMEOUT_MS=600000
# BUILDER_REPAIR_ATTEMPTS=1
# BUILDER_POLL_INTERVAL_MS=5000
# BUILDER_WORKSPACE_DIR=
# BUILDER_ISOLATION_MODE=auto
# BUILDER_RUNS_DIR=
# BUILDER_BRANCH_PREFIX=codex/founderos-build
# BUILDER_CLEAN_WORKSPACE_AFTER_RUN=

# opencode adapter (BUILDER_PROVIDER=opencode)
# BUILDER_OPENCODE_COMMAND=opencode
# BUILDER_OPENCODE_MODEL=
# BUILDER_OPENCODE_AGENT=
# BUILDER_OPENCODE_ATTACH_URL=

# Optional manual DeepSeek adapter (BUILDER_PROVIDER=deepseek)
# This is a legacy/direct chat-completions path, not the default builder route.
# DEEPSEEK_API_KEY=

# Optional manual Z.ai adapter (BUILDER_PROVIDER=zai)
# Default paid GLM routing uses opencode auth instead; do not set this for normal setup.
# FOUNDEROS_ENABLE_DIRECT_ZAI=false
# ZAI_API_KEY=

# OpenRouter adapter (BUILDER_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Generic LLM adapter (BUILDER_PROVIDER=llm)
# BUILDER_LLM_API_KEY=
# BUILDER_LLM_CHAT_COMPLETIONS_URL=
# BUILDER_LLM_MODEL=

# Codex adapter (BUILDER_PROVIDER=codex)
# OPENAI_API_KEY=
# BUILDER_CODEX_MODEL=
# BUILDER_CODEX_REASONING_EFFORT=medium

# Builder checks / tests
# BUILDER_INSTALL_COMMANDS=
# BUILDER_SKIP_INSTALL=false
# BUILDER_INSTALL_TIMEOUT_MS=180000
# BUILDER_TEST_COMMANDS=
# BUILDER_SKIP_TESTS=false
# BUILDER_TEST_TIMEOUT_MS=120000

# Builder local preview
# BUILDER_PREVIEW_URL=http://localhost:3000
# BUILDER_PREVIEW_PORT=3100
# BUILDER_PREVIEW_PROVIDER=local
# BUILDER_START_PREVIEW=true
# BUILDER_PREVIEW_COMMAND=npm run dev
# BUILDER_PREVIEW_TIMEOUT_MS=30000
# BUILDER_BROWSER_QA_MODE=http
# BUILDER_SKIP_BROWSER_QA=false

# Builder Vercel previews
# BUILDER_VERCEL_PREVIEWS=false
# BUILDER_VERCEL_TOKEN=
# BUILDER_VERCEL_PROJECT_ID=
# BUILDER_VERCEL_PROJECT_NAME=
# BUILDER_VERCEL_TEAM_ID=
# BUILDER_VERCEL_PRODUCTION_DOMAIN=
