# FounderOS platform environment
#
# Only put FounderOS-owned infrastructure secrets here.
# User-owned connector credentials are collected in onboarding or Settings and
# stored encrypted per workspace.

# Convex
CONVEX_DEPLOYMENT=
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3000

# Worker authorization
FOUNDEROS_WORKER_TOKEN=

# Connector credential encryption
CONNECTOR_SECRET_ENCRYPTION_KEY=

# FounderOS-owned Google OAuth app
# Used for login and, unless overridden below, Google Workspace connectors.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional FounderOS-owned connector OAuth apps
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Optional FounderOS-owned GitHub App
GITHUB_APP_NAME=founderos-connect
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Builder worker
# See workers/builder/README.md for full documentation.
BUILDER_PROVIDER=simulated
# BUILDER_AGENT=
# BUILDER_AGENT_TIMEOUT_MS=600000
# BUILDER_REPAIR_ATTEMPTS=1
# BUILDER_POLL_INTERVAL_MS=5000
# BUILDER_WORKSPACE_DIR=
# BUILDER_ISOLATION_MODE=auto
# BUILDER_RUNS_DIR=
# BUILDER_BRANCH_PREFIX=codex/founderos-build
# BUILDER_CLEAN_WORKSPACE_AFTER_RUN=

# OpenCode adapter (BUILDER_PROVIDER=opencode)
# BUILDER_OPENCODE_COMMAND=opencode
# BUILDER_OPENCODE_MODEL=
# BUILDER_OPENCODE_AGENT=
# BUILDER_OPENCODE_ATTACH_URL=

# DeepSeek adapter (BUILDER_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=

# Z.ai adapter (BUILDER_PROVIDER=zai)
# ZAI_API_KEY=

# OpenRouter adapter (BUILDER_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Generic LLM adapter (BUILDER_PROVIDER=llm)
# BUILDER_LLM_API_KEY=
# BUILDER_LLM_CHAT_COMPLETIONS_URL=
# BUILDER_LLM_MODEL=

# Codex adapter (BUILDER_PROVIDER=codex)
# OPENAI_API_KEY=
# BUILDER_CODEX_MODEL=
# BUILDER_CODEX_REASONING_EFFORT=medium

# Builder checks / tests
# BUILDER_TEST_COMMANDS=
# BUILDER_SKIP_TESTS=false
# BUILDER_TEST_TIMEOUT_MS=120000

# Builder local preview
# BUILDER_PREVIEW_URL=http://localhost:3000
# BUILDER_PREVIEW_PROVIDER=local
# BUILDER_START_PREVIEW=false
# BUILDER_PREVIEW_COMMAND=npm run dev
# BUILDER_PREVIEW_TIMEOUT_MS=30000

# Builder Vercel previews
# BUILDER_VERCEL_PREVIEWS=false
# BUILDER_VERCEL_TOKEN=
# BUILDER_VERCEL_PROJECT_ID=
# BUILDER_VERCEL_PROJECT_NAME=
# BUILDER_VERCEL_TEAM_ID=
# BUILDER_VERCEL_PRODUCTION_DOMAIN=
